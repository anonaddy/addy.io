{
    "private": true,
    "scripts": {
        "staging": "npm run vite:build && npm run jigsaw:staging",
        "production": "npm run vite:build && npm run jigsaw:production",
        "dev": "npm run vite:build && npm run jigsaw:local",
        "prod": "npm run production",
        "prod-serve": "npm run production && browser-sync start --server build_production --files \"build_production/**/*\" --port 3000 --no-open --no-notify --no-ui",
        "watch": "npm run dev && concurrently -k -n assets,site,manifest,serve,reload \"npm:watch:assets\" \"npm:watch:site\" \"npm:watch:manifest\" \"npm:watch:serve\" \"npm:watch:reload\"",
        "watch:assets": "vite build --watch",
        "watch:site": "chokidar \"source/**/*\" --ignored \"source/assets/build/**\" --debounce 400 -c \"npm run jigsaw:local\"",
        "watch:manifest": "chokidar \"source/assets/build/manifest.json\" --debounce 500 -c \"npm run jigsaw:local\"",
        "watch:serve": "browser-sync start --server build_local --port 3000 --no-open --no-notify --no-ui",
        "watch:reload": "chokidar \"build_local/**/*.html\" \"build_local/**/*.xml\" --debounce 750 -c \"browser-sync reload --port 3000\"",
        "vite:build": "vite build",
        "jigsaw:local": "./vendor/bin/jigsaw build -q local",
        "jigsaw:staging": "cross-env NODE_ENV=staging ./vendor/bin/jigsaw build -q staging",
        "jigsaw:production": "cross-env NODE_ENV=production ./vendor/bin/jigsaw build -q production",
        "format": "prettier --write 'source/_assets/**/*.{css,js,vue}'",
        "optimize:help-images": "bash scripts/optimize-help-screenshots.sh",
        "optimize:help-images:list": "bash scripts/optimize-help-screenshots.sh --list-only",
        "pre-commit": "lint-staged",
        "prepare": "husky"
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4.1.12",
        "axios": "^1.16.0",
        "browser-sync": "^3.0.0",
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "fuse.js": "^7.0.0",
        "highlight.js": "^11.0.0",
        "lottie-web": "^5.13.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.12",
        "vite": "^8.0.10",
        "vue": "^3.0.0",
        "vue-template-compiler": "^2.6.12"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.6",
        "chokidar-cli": "^3.0.0",
        "css-loader": "^7.0.0",
        "husky": "^9.0.0",
        "lint-staged": "^17.0.0",
        "prettier": "^3.0.0"
    },
    "lint-staged": {
        "source/_assets/**/*.{css,js,vue}": [
            "prettier --write"
        ],
        "*.php": [
            "composer format"
        ]
    }
}
